#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
USERS_DIR="$REPO_DIR/users"
STARTER_KIT_DIR="$REPO_DIR/starter-kit"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

usage() {
  cat <<EOF
${BOLD}skills-browse${RESET} — 社内スキルのブラウズ・フォークツール

${BOLD}USAGE${RESET}
  skills-browse <command> [options]

${BOLD}COMMANDS${RESET}
  join                         このリポジトリに参加する（初回セットアップ）
  doctor                       ローカル環境の状態を診断する
  list                         全スキルの一覧を表示
  search <keyword>             キーワードで SKILL.md を全文検索
  show <user>/<skill>          スキルの詳細を表示
  install <user>/<skill>       スキルを自分のディレクトリにフォーク
  setup                        ローカル環境のセットアップ（シンボリックリンク作成）
  users                        参加ユーザー一覧

${BOLD}OPTIONS (join)${RESET}
  --me <name>                  自分の GitHub ユーザー名（省略時は gh/git から取得）
  --gh-user <name>             CODEOWNERS 用の GitHub ユーザー名（--me と異なる場合）

${BOLD}OPTIONS (list)${RESET}
  --user <name>                特定ユーザーのスキルのみ表示

${BOLD}OPTIONS (install)${RESET}
  --me <name>                  自分の GitHub ユーザー名（省略時は gh/git から取得）

${BOLD}OPTIONS (setup)${RESET}
  --me <name>                  自分の GitHub ユーザー名（省略時は gh/git から取得）
  --agent <claude|cursor|all>  対象エージェント (デフォルト: all)

${BOLD}OPTIONS (doctor)${RESET}
  --me <name>                  自分の GitHub ユーザー名（省略時は gh/git から取得）

${BOLD}EXAMPLES${RESET}
  skills-browse join --me my-name
  skills-browse doctor
  skills-browse list
  skills-browse search "テスト"
  skills-browse install sample-user/test-generator
  skills-browse setup --agent claude
EOF
}

# --- Helpers ---

get_my_username() {
  local me="${1:-}"
  if [[ -n "$me" ]]; then
    echo "$me"
    return
  fi
  gh api user --jq '.login' 2>/dev/null || \
    git config user.name 2>/dev/null | tr ' ' '-' | tr '[:upper:]' '[:lower:]' || true
}

get_gh_username() {
  local gh_user="${1:-}"
  if [[ -n "$gh_user" ]]; then
    echo "$gh_user"
    return
  fi
  gh api user --jq '.login' 2>/dev/null || true
}

parse_frontmatter() {
  local file="$1"
  local key="$2"
  sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null \
    | grep -E "^${key}:" \
    | sed "s/^${key}:[[:space:]]*//" \
    | sed 's/^["'\'']\(.*\)["'\''"]$/\1/'
}

find_skills() {
  local search_dir="$1"
  find "$search_dir" -name "SKILL.md" -not -path "*/.template/*" 2>/dev/null | sort
}

skill_info_from_path() {
  local skill_path="$1"
  local rel="${skill_path#"$REPO_DIR"/}"
  local user=""
  local skill_name=""

  if [[ "$rel" == users/* ]]; then
    user=$(echo "$rel" | cut -d/ -f2)
    skill_name=$(basename "$(dirname "$skill_path")")
  elif [[ "$rel" == starter-kit/* ]]; then
    user="starter-kit"
    skill_name=$(basename "$(dirname "$skill_path")")
  fi

  echo "$user" "$skill_name"
}

# --- Commands ---

cmd_users() {
  echo -e "${BOLD}Registered Users${RESET}"
  echo ""
  for dir in "$USERS_DIR"/*/; do
    local name
    name=$(basename "$dir")
    [[ "$name" == ".template" ]] && continue
    local skill_count
    skill_count=$(find_skills "$dir" | wc -l | tr -d ' ')
    echo -e "  ${CYAN}${name}${RESET}  ${DIM}(${skill_count} skills)${RESET}"
  done
}

cmd_list() {
  local filter_user=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user) filter_user="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local search_dir="$REPO_DIR"
  if [[ -n "$filter_user" ]]; then
    if [[ "$filter_user" == "starter-kit" ]]; then
      search_dir="$STARTER_KIT_DIR"
    else
      search_dir="$USERS_DIR/$filter_user"
    fi
    if [[ ! -d "$search_dir" ]]; then
      echo -e "${RED}Error: User '$filter_user' not found${RESET}" >&2
      exit 1
    fi
  fi

  local found=0
  echo -e "${BOLD}Available Skills${RESET}"
  echo ""

  while IFS= read -r skill_path; do
    read -r user skill_name <<< "$(skill_info_from_path "$skill_path")"
    [[ -z "$user" ]] && continue

    local desc
    desc=$(parse_frontmatter "$skill_path" "description")
    [[ -z "$desc" ]] && desc="${DIM}(no description)${RESET}"

    printf "  ${CYAN}%-22s${RESET} ${GREEN}%-20s${RESET} %s\n" \
      "$user" "$skill_name" "$desc"
    found=$((found + 1))
  done < <(find_skills "$search_dir")

  echo ""
  echo -e "${DIM}${found} skill(s) found${RESET}"
}

cmd_search() {
  local keyword="${1:-}"
  if [[ -z "$keyword" ]]; then
    echo -e "${RED}Error: Search keyword is required${RESET}" >&2
    echo "Usage: skills-browse search <keyword>"
    exit 1
  fi

  echo -e "${BOLD}Search results for '${keyword}'${RESET}"
  echo ""

  local found=0
  while IFS= read -r skill_path; do
    if grep -F -qi "$keyword" "$skill_path" 2>/dev/null; then
      read -r user skill_name <<< "$(skill_info_from_path "$skill_path")"
      [[ -z "$user" ]] && continue

      local desc
      desc=$(parse_frontmatter "$skill_path" "description")
      [[ -z "$desc" ]] && desc="${DIM}(no description)${RESET}"

      printf "  ${CYAN}%-22s${RESET} ${GREEN}%-20s${RESET} %s\n" \
        "$user" "$skill_name" "$desc"

      grep -F -n -i --color=always "$keyword" "$skill_path" 2>/dev/null | head -3 | while IFS= read -r line; do
        echo "    $line"
      done
      echo ""
      found=$((found + 1))
    fi
  done < <(find_skills "$REPO_DIR")

  echo -e "${DIM}${found} skill(s) matched${RESET}"
}

cmd_show() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo -e "${RED}Error: Specify <user>/<skill>${RESET}" >&2
    exit 1
  fi

  local user="${target%%/*}"
  local skill_name="${target#*/}"

  local skill_path=""
  while IFS= read -r path; do
    read -r u s <<< "$(skill_info_from_path "$path")"
    if [[ "$u" == "$user" && "$s" == "$skill_name" ]]; then
      skill_path="$path"
      break
    fi
  done < <(find_skills "$REPO_DIR")

  if [[ -z "$skill_path" ]]; then
    echo -e "${RED}Error: Skill '${target}' not found${RESET}" >&2
    exit 1
  fi

  local name desc
  name=$(parse_frontmatter "$skill_path" "name")
  desc=$(parse_frontmatter "$skill_path" "description")

  echo -e "${BOLD}${name:-$skill_name}${RESET}"
  echo -e "${DIM}Owner: ${user}${RESET}"
  [[ -n "$desc" ]] && echo -e "${DIM}${desc}${RESET}"
  echo -e "${DIM}Path: ${skill_path}${RESET}"
  echo ""
  echo "---"
  cat "$skill_path"
}

cmd_install() {
  local target=""
  local me=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --me) me="$2"; shift 2 ;;
      *) target="$1"; shift ;;
    esac
  done

  if [[ -z "$target" ]]; then
    echo -e "${RED}Error: Specify <user>/<skill> or 'starter-kit/<skill>'${RESET}" >&2
    exit 1
  fi

  me=$(get_my_username "$me")
  if [[ -z "$me" ]]; then
    echo -e "${RED}Error: Cannot determine your username. Use --me <name>${RESET}" >&2
    exit 1
  fi

  local source_user="${target%%/*}"
  local skill_name="${target#*/}"

  if [[ "$source_user" == "$me" ]]; then
    echo -e "${RED}Error: Cannot fork your own skill${RESET}" >&2
    exit 1
  fi

  # Find the source skill
  local source_path=""
  while IFS= read -r path; do
    read -r u s <<< "$(skill_info_from_path "$path")"
    if [[ "$u" == "$source_user" && "$s" == "$skill_name" ]]; then
      source_path="$(dirname "$path")"
      break
    fi
  done < <(find_skills "$REPO_DIR")

  if [[ -z "$source_path" ]]; then
    echo -e "${RED}Error: Skill '${target}' not found${RESET}" >&2
    exit 1
  fi

  local dest="$USERS_DIR/$me/$skill_name"

  if [[ -e "$dest" ]]; then
    echo -e "${YELLOW}Skip: ${skill_name} already exists in your directory${RESET}"
    echo -e "${DIM}  ${dest}${RESET}"
    exit 0
  fi

  # Ensure user directory exists
  mkdir -p "$USERS_DIR/$me"

  cp -r "$source_path" "$dest"
  echo -e "${GREEN}Forked: ${source_user}/${skill_name} → users/${me}/${skill_name}${RESET}"
  echo ""
  echo -e "${DIM}Next steps:${RESET}"
  echo -e "${DIM}  1. Edit ${dest}/SKILL.md to customize${RESET}"
  echo -e "${DIM}  2. git add users/${me}/${skill_name}${RESET}"
  echo -e "${DIM}  3. git commit & push${RESET}"
}

cmd_join() {
  local me=""
  local gh_user=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --me) me="$2"; shift 2 ;;
      --gh-user) gh_user="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  me=$(get_my_username "$me")
  if [[ -z "$me" ]]; then
    echo -e "${RED}Error: Cannot determine your username. Use --me <name>${RESET}" >&2
    exit 1
  fi

  gh_user=$(get_gh_username "$gh_user")
  if [[ -z "$gh_user" ]]; then
    gh_user="$me"
    echo -e "${YELLOW}Note: Could not detect GitHub username. Using '${me}' for CODEOWNERS.${RESET}"
    echo -e "${YELLOW}  If this is wrong, re-run with --gh-user <github-username>${RESET}"
    echo ""
  fi

  local my_dir="$USERS_DIR/$me"

  # Step 1: Check if already joined
  if [[ -d "$my_dir" ]]; then
    echo -e "${YELLOW}Directory users/${me} already exists. Skipping creation.${RESET}"
  else
    echo -e "${BOLD}[1/4] Creating directory from template...${RESET}"
    cp -r "$USERS_DIR/.template" "$my_dir"
    echo -e "${GREEN}  Created users/${me}/${RESET}"
  fi

  # Step 2: Update CODEOWNERS
  local codeowners="$REPO_DIR/CODEOWNERS"
  local owner_entry="/users/${me}/   @${gh_user}"

  if grep -q "/users/${me}/" "$codeowners" 2>/dev/null; then
    echo -e "${DIM}[2/4] CODEOWNERS entry already exists. Skipping.${RESET}"
  else
    echo -e "${BOLD}[2/4] Adding CODEOWNERS entry...${RESET}"
    local marker="# Shared resources require maintainer review"
    sed -i '' "s|${marker}|${owner_entry}\n\n${marker}|" "$codeowners"
    echo -e "${GREEN}  Added: ${owner_entry}${RESET}"
  fi

  # Step 3: Create branch and commit
  echo -e "${BOLD}[3/4] Creating commit...${RESET}"
  local branch="add-${me}"

  git -C "$REPO_DIR" checkout -b "$branch" 2>/dev/null || git -C "$REPO_DIR" checkout "$branch" 2>/dev/null || true
  git -C "$REPO_DIR" add "users/${me}/" CODEOWNERS
  git -C "$REPO_DIR" commit -m "Add ${me}" --quiet
  echo -e "${GREEN}  Committed on branch ${branch}${RESET}"

  # Step 4: Push and create PR
  echo -e "${BOLD}[4/4] Pushing and creating PR...${RESET}"
  git -C "$REPO_DIR" push -u origin "$branch" --quiet 2>&1

  if command -v gh &>/dev/null; then
    local pr_url
    pr_url=$(gh pr create \
      --repo "$(git -C "$REPO_DIR" remote get-url origin)" \
      --title "Add ${me}" \
      --body "## New member: ${me}

- Created \`users/${me}/\` from template
- Added CODEOWNERS entry: \`${owner_entry}\`" \
      2>&1) || true

    if [[ -n "$pr_url" ]]; then
      echo -e "${GREEN}  PR created: ${pr_url}${RESET}"
    fi
  else
    echo -e "${DIM}  gh CLI not found. Create a PR manually on GitHub.${RESET}"
  fi

  echo ""
  echo -e "${BOLD}Done!${RESET} Next steps:"
  echo -e "  1. Wait for PR to be merged (CODEOWNERS change requires maintainer approval)"
  echo -e "  2. Run ${CYAN}./scripts/skills-browse setup --me ${me}${RESET} to link your skills locally"
  echo -e "  3. Add your first skill to ${CYAN}users/${me}/${RESET}"
}

cmd_doctor() {
  local me=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --me) me="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  me=$(get_my_username "$me")
  if [[ -z "$me" ]]; then
    echo -e "${RED}Error: Cannot determine your username. Use --me <name>${RESET}" >&2
    exit 1
  fi

  echo -e "${BOLD}Skills Sharing Doctor${RESET}"
  echo -e "${DIM}User: ${me}${RESET}"
  echo ""

  local issues=0

  # Check 1: User directory exists
  local my_dir="$USERS_DIR/$me"
  if [[ -d "$my_dir" ]]; then
    echo -e "  ${GREEN}✓${RESET} users/${me}/ exists"
  else
    echo -e "  ${RED}✗${RESET} users/${me}/ not found"
    echo -e "    ${DIM}Run: ./scripts/skills-browse join --me ${me}${RESET}"
    issues=$((issues + 1))
  fi

  # Check 2: CODEOWNERS entry
  local codeowners="$REPO_DIR/CODEOWNERS"
  if grep -q "/users/${me}/" "$codeowners" 2>/dev/null; then
    echo -e "  ${GREEN}✓${RESET} CODEOWNERS entry found"
  else
    echo -e "  ${RED}✗${RESET} CODEOWNERS entry missing"
    echo -e "    ${DIM}Run: ./scripts/skills-browse join --me ${me}${RESET}"
    issues=$((issues + 1))
  fi

  # Check 3: Skills count
  if [[ -d "$my_dir" ]]; then
    local skill_count
    skill_count=$(find_skills "$my_dir" | wc -l | tr -d ' ')
    if [[ "$skill_count" -gt 0 ]]; then
      echo -e "  ${GREEN}✓${RESET} ${skill_count} skill(s) in your directory"
      find_skills "$my_dir" | while IFS= read -r path; do
        local sname
        sname=$(basename "$(dirname "$path")")
        echo -e "    ${DIM}- ${sname}${RESET}"
      done
    else
      echo -e "  ${YELLOW}△${RESET} No skills yet"
      echo -e "    ${DIM}Add a SKILL.md to get started${RESET}"
    fi
  fi

  # Check 4: Agent symlinks
  for agent in claude cursor; do
    local dest="$HOME/.${agent}/skills"
    if [[ -L "$dest" ]]; then
      local target
      target=$(readlink "$dest")
      if [[ "$target" == "$my_dir" ]]; then
        echo -e "  ${GREEN}✓${RESET} ~/.${agent}/skills → ${my_dir}"
      else
        echo -e "  ${YELLOW}△${RESET} ~/.${agent}/skills → ${target} (not linked to your directory)"
        echo -e "    ${DIM}Expected: ${my_dir}${RESET}"
        issues=$((issues + 1))
      fi
    elif [[ -d "$dest" ]]; then
      echo -e "  ${YELLOW}△${RESET} ~/.${agent}/skills/ is a directory (not a symlink)"
      echo -e "    ${DIM}Back up and remove, then run: ./scripts/skills-browse setup --me ${me} --agent ${agent}${RESET}"
      issues=$((issues + 1))
    else
      echo -e "  ${RED}✗${RESET} ~/.${agent}/skills not found"
      echo -e "    ${DIM}Run: ./scripts/skills-browse setup --me ${me} --agent ${agent}${RESET}"
      issues=$((issues + 1))
    fi
  done

  # Check 5: Git status
  echo ""
  local unpushed
  unpushed=$(git -C "$REPO_DIR" log --oneline origin/main..HEAD 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$unpushed" -gt 0 ]]; then
    echo -e "  ${YELLOW}△${RESET} ${unpushed} unpushed commit(s)"
    echo -e "    ${DIM}Run: git push${RESET}"
  else
    echo -e "  ${GREEN}✓${RESET} Up to date with remote"
  fi

  # Summary
  echo ""
  if [[ "$issues" -eq 0 ]]; then
    echo -e "${GREEN}All checks passed!${RESET}"
  else
    echo -e "${YELLOW}${issues} issue(s) found. See suggestions above.${RESET}"
  fi
}

cmd_setup() {
  local me=""
  local agent="all"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --me) me="$2"; shift 2 ;;
      --agent) agent="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  me=$(get_my_username "$me")
  if [[ -z "$me" ]]; then
    echo -e "${RED}Error: Cannot determine your username. Use --me <name>${RESET}" >&2
    exit 1
  fi

  local my_dir="$USERS_DIR/$me"
  if [[ ! -d "$my_dir" ]]; then
    echo -e "${RED}Error: Directory users/${me} not found. Create it first.${RESET}" >&2
    exit 1
  fi

  local agents=()
  case "$agent" in
    all)    agents=(claude cursor) ;;
    claude) agents=(claude) ;;
    cursor) agents=(cursor) ;;
    *)
      echo -e "${RED}Error: Unknown agent '${agent}'. Use claude, cursor, or all${RESET}" >&2
      exit 1
      ;;
  esac

  for a in "${agents[@]}"; do
    local dest="$HOME/.${a}/skills"

    if [[ -L "$dest" ]]; then
      local current_target
      current_target=$(readlink "$dest")
      if [[ "$current_target" == "$my_dir" ]]; then
        echo -e "${DIM}Skip: ~/.${a}/skills already linked to ${my_dir}${RESET}"
        continue
      fi
      echo -e "${YELLOW}Warning: ~/.${a}/skills is already a symlink → ${current_target}${RESET}"
      echo -e "${YELLOW}  Remove it first if you want to re-link: rm ~/.${a}/skills${RESET}"
      continue
    fi

    if [[ -d "$dest" ]]; then
      echo -e "${YELLOW}Warning: ~/.${a}/skills/ is an existing directory${RESET}"
      echo -e "${YELLOW}  Back it up and remove it to use symlink: mv ~/.${a}/skills ~/.${a}/skills.bak${RESET}"
      continue
    fi

    mkdir -p "$(dirname "$dest")"
    ln -s "$my_dir" "$dest"
    echo -e "${GREEN}Linked: ~/.${a}/skills → ${my_dir}${RESET}"
  done
}

# --- Main ---

command="${1:-}"
shift || true

case "$command" in
  join)    cmd_join "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  list)    cmd_list "$@" ;;
  search)  cmd_search "$@" ;;
  show)    cmd_show "$@" ;;
  install) cmd_install "$@" ;;
  setup)   cmd_setup "$@" ;;
  users)   cmd_users ;;
  -h|--help|help|"") usage ;;
  *)
    echo -e "${RED}Unknown command: ${command}${RESET}" >&2
    usage
    exit 1
    ;;
esac
