#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
USERS_DIR="$REPO_DIR/users"
STARTER_KIT_DIR="$REPO_DIR/starter-kit"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

usage() {
  cat <<EOF
${BOLD}skills-browse${RESET} — 社内スキルのブラウズ・インストールツール

${BOLD}USAGE${RESET}
  skills-browse <command> [options]

${BOLD}COMMANDS${RESET}
  list                         全スキルの一覧を表示
  search <keyword>             キーワードで SKILL.md を全文検索
  show <user>/<skill>          スキルの詳細を表示
  install <user>/<skill>       スキルをローカルにインストール
  users                        参加ユーザー一覧

${BOLD}OPTIONS (list)${RESET}
  --user <name>                特定ユーザーのスキルのみ表示
  --agent <claude|cursor>      特定エージェントのスキルのみ表示

${BOLD}OPTIONS (install)${RESET}
  --agent <claude|cursor>      インストール先のエージェント (必須)
  --global                     ユーザーレベル (~/) にインストール
  --copy                       シンボリックリンクの代わりにコピー

${BOLD}EXAMPLES${RESET}
  skills-browse list
  skills-browse list --user akira-yui
  skills-browse search "PR レビュー"
  skills-browse show tomoya-nakatani/dev-workflow
  skills-browse install akira-yui/code-refactor --agent claude
EOF
}

# --- Helpers ---

parse_frontmatter() {
  local file="$1"
  local key="$2"
  sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null \
    | grep -E "^${key}:" \
    | sed "s/^${key}:[[:space:]]*//" \
    | sed 's/^["'\'']\(.*\)["'\''"]$/\1/'
}

find_skills() {
  local search_dir="$1"
  find "$search_dir" -name "SKILL.md" -not -path "*/.template/*" 2>/dev/null | sort
}

skill_info_from_path() {
  local skill_path="$1"
  local rel="${skill_path#"$REPO_DIR"/}"

  local user=""
  local agent=""
  local skill_name=""

  if [[ "$rel" == users/* ]]; then
    user=$(echo "$rel" | cut -d/ -f2)
    agent=$(echo "$rel" | cut -d/ -f3)
    skill_name=$(basename "$(dirname "$skill_path")")
  elif [[ "$rel" == starter-kit/* ]]; then
    user="starter-kit"
    agent=$(echo "$rel" | cut -d/ -f2)
    skill_name=$(basename "$(dirname "$skill_path")")
  fi

  echo "$user" "$agent" "$skill_name"
}

# --- Commands ---

cmd_users() {
  echo -e "${BOLD}Registered Users${RESET}"
  echo ""
  for dir in "$USERS_DIR"/*/; do
    local name
    name=$(basename "$dir")
    [[ "$name" == ".template" ]] && continue
    local skill_count
    skill_count=$(find_skills "$dir" | wc -l | tr -d ' ')
    echo -e "  ${CYAN}${name}${RESET}  ${DIM}(${skill_count} skills)${RESET}"
  done
}

cmd_list() {
  local filter_user=""
  local filter_agent=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user) filter_user="$2"; shift 2 ;;
      --agent) filter_agent="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local search_dir="$REPO_DIR"
  if [[ -n "$filter_user" ]]; then
    if [[ "$filter_user" == "starter-kit" ]]; then
      search_dir="$STARTER_KIT_DIR"
    else
      search_dir="$USERS_DIR/$filter_user"
    fi
    if [[ ! -d "$search_dir" ]]; then
      echo -e "${RED}Error: User '$filter_user' not found${RESET}" >&2
      exit 1
    fi
  fi

  local found=0
  echo -e "${BOLD}Available Skills${RESET}"
  echo ""

  while IFS= read -r skill_path; do
    read -r user agent skill_name <<< "$(skill_info_from_path "$skill_path")"
    [[ -z "$user" ]] && continue
    [[ -n "$filter_agent" && "$agent" != "$filter_agent" ]] && continue

    local desc
    desc=$(parse_frontmatter "$skill_path" "description")
    [[ -z "$desc" ]] && desc="${DIM}(no description)${RESET}"

    printf "  ${CYAN}%-22s${RESET} ${GREEN}%-20s${RESET} ${YELLOW}%-8s${RESET} %s\n" \
      "$user" "$skill_name" "$agent" "$desc"
    found=$((found + 1))
  done < <(find_skills "$search_dir")

  echo ""
  echo -e "${DIM}${found} skill(s) found${RESET}"
}

cmd_search() {
  local keyword="${1:-}"
  if [[ -z "$keyword" ]]; then
    echo -e "${RED}Error: Search keyword is required${RESET}" >&2
    echo "Usage: skills-browse search <keyword>"
    exit 1
  fi

  echo -e "${BOLD}Search results for '${keyword}'${RESET}"
  echo ""

  local found=0
  while IFS= read -r skill_path; do
    if grep -qi "$keyword" "$skill_path" 2>/dev/null; then
      read -r user agent skill_name <<< "$(skill_info_from_path "$skill_path")"
      [[ -z "$user" ]] && continue

      local desc
      desc=$(parse_frontmatter "$skill_path" "description")
      [[ -z "$desc" ]] && desc="${DIM}(no description)${RESET}"

      printf "  ${CYAN}%-22s${RESET} ${GREEN}%-20s${RESET} ${YELLOW}%-8s${RESET} %s\n" \
        "$user" "$skill_name" "$agent" "$desc"

      grep -n -i --color=always "$keyword" "$skill_path" 2>/dev/null | head -3 | while IFS= read -r line; do
        echo "    $line"
      done
      echo ""
      found=$((found + 1))
    fi
  done < <(find_skills "$REPO_DIR")

  echo -e "${DIM}${found} skill(s) matched${RESET}"
}

cmd_show() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo -e "${RED}Error: Specify <user>/<skill>${RESET}" >&2
    exit 1
  fi

  local user="${target%%/*}"
  local skill_name="${target#*/}"

  local skill_path=""
  while IFS= read -r path; do
    read -r u _ s <<< "$(skill_info_from_path "$path")"
    if [[ "$u" == "$user" && "$s" == "$skill_name" ]]; then
      skill_path="$path"
      break
    fi
  done < <(find_skills "$REPO_DIR")

  if [[ -z "$skill_path" ]]; then
    echo -e "${RED}Error: Skill '${target}' not found${RESET}" >&2
    exit 1
  fi

  local name desc agent
  name=$(parse_frontmatter "$skill_path" "name")
  desc=$(parse_frontmatter "$skill_path" "description")
  read -r _ agent _ <<< "$(skill_info_from_path "$skill_path")"

  echo -e "${BOLD}${name:-$skill_name}${RESET}"
  echo -e "${DIM}Owner: ${user} | Agent: ${agent}${RESET}"
  [[ -n "$desc" ]] && echo -e "${DIM}${desc}${RESET}"
  echo -e "${DIM}Path: ${skill_path}${RESET}"
  echo ""
  echo "---"
  cat "$skill_path"
}

cmd_install() {
  local target=""
  local agent=""
  local global=false
  local copy=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent) agent="$2"; shift 2 ;;
      --global) global=true; shift ;;
      --copy) copy=true; shift ;;
      *) target="$1"; shift ;;
    esac
  done

  if [[ -z "$target" ]]; then
    echo -e "${RED}Error: Specify <user>/<skill> or 'starter-kit'${RESET}" >&2
    exit 1
  fi
  if [[ -z "$agent" ]]; then
    echo -e "${RED}Error: --agent is required (claude or cursor)${RESET}" >&2
    exit 1
  fi

  # Determine destination
  local dest_base
  case "$agent" in
    claude)
      if $global; then
        dest_base="$HOME/.claude/skills"
      else
        dest_base=".claude/skills"
      fi
      ;;
    cursor)
      if $global; then
        dest_base="$HOME/.cursor/skills"
      else
        dest_base=".cursor/skills"
      fi
      ;;
    *)
      echo -e "${RED}Error: Unknown agent '${agent}'. Use 'claude' or 'cursor'${RESET}" >&2
      exit 1
      ;;
  esac

  # Find matching skills
  local skills_to_install=()

  if [[ "$target" == "starter-kit" ]]; then
    while IFS= read -r path; do
      read -r _ a _ <<< "$(skill_info_from_path "$path")"
      [[ "$a" == "$agent" ]] && skills_to_install+=("$path")
    done < <(find_skills "$STARTER_KIT_DIR")
  else
    local user="${target%%/*}"
    local skill_name="${target#*/}"

    while IFS= read -r path; do
      read -r u a s <<< "$(skill_info_from_path "$path")"
      if [[ "$u" == "$user" && "$s" == "$skill_name" && "$a" == "$agent" ]]; then
        skills_to_install+=("$path")
        break
      fi
    done < <(find_skills "$REPO_DIR")
  fi

  if [[ ${#skills_to_install[@]} -eq 0 ]]; then
    echo -e "${RED}Error: No skills found for '${target}' (agent: ${agent})${RESET}" >&2
    exit 1
  fi

  # Install each skill
  for skill_path in "${skills_to_install[@]}"; do
    local skill_dir
    skill_dir=$(dirname "$skill_path")
    local skill_name
    skill_name=$(basename "$skill_dir")
    local dest="$dest_base/$skill_name"

    mkdir -p "$(dirname "$dest")"

    if [[ -e "$dest" ]]; then
      echo -e "${YELLOW}Skip: ${skill_name} (already exists at ${dest})${RESET}"
      continue
    fi

    if $copy; then
      cp -r "$skill_dir" "$dest"
      echo -e "${GREEN}Copied: ${skill_name} → ${dest}${RESET}"
    else
      ln -s "$skill_dir" "$dest"
      echo -e "${GREEN}Linked: ${skill_name} → ${dest}${RESET}"
    fi
  done

  echo ""
  echo -e "${DIM}Done. Installed ${#skills_to_install[@]} skill(s) to ${dest_base}${RESET}"
}

# --- Main ---

command="${1:-}"
shift || true

case "$command" in
  list)    cmd_list "$@" ;;
  search)  cmd_search "$@" ;;
  show)    cmd_show "$@" ;;
  install) cmd_install "$@" ;;
  users)   cmd_users ;;
  -h|--help|help|"") usage ;;
  *)
    echo -e "${RED}Unknown command: ${command}${RESET}" >&2
    usage
    exit 1
    ;;
esac
